APP_NAME=Enterprise AI Knowledge Assistant
ENVIRONMENT=production

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-real-strong-password
POSTGRES_DB=knowledge_assistant

JWT_SECRET_KEY=generate-a-new-random-secret-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

CHROMA_HOST=chromadb
CHROMA_PORT=8000

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=25

ENABLE_CLOUDWATCH_LOGGING=false
CLOUDWATCH_LOG_GROUP=knowledge-assistant
CLOUDWATCH_LOG_STREAM=backend

CORS_ALLOWED_ORIGINS=["http://<your-ec2-public-ip>"]